# ─────────────────────────────────────────────────────────────────────────────
# StayPilot — Backend .env.example
# ⚠ CE FICHIER NE DOIT JAMAIS CONTENIR DE VRAIES CLÉS API
# Copier en .env et remplir avec vos valeurs réelles (jamais committer .env)
# ─────────────────────────────────────────────────────────────────────────────

# ============================================================
# À REMPLIR POUR CHAQUE CLIENT
# ============================================================

# Infos conciergerie (affichées dans les PDFs)
CLIENT_NAME=Ma Conciergerie
CLIENT_LOGO_URL=                # URL du logo (hébergé sur S3 ou CDN)
CLIENT_PHONE=
CLIENT_ADDRESS=
CLIENT_SIRET=
CLIENT_COMMISSION_RATE=20       # Taux de commission en % (ex: 20)

# ============================================================
# CHANNEL MANAGER — configuré par logement dans l'interface
# ============================================================
# Smoobu, Hostaway, Lodgify : clés saisies par logement dans l'UI
SUPERHOTE_API_KEY=votre-cle-superhote-ici

# Numéros Twilio
TWILIO_PHONE_SMS=+33XXXXXXXXX       # Numéro Twilio pour les SMS sortants (format E.164)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX    # Alias legacy (inutilisé, conservé pour compatibilité)

# ============================================================
# INFRASTRUCTURE
# ============================================================

# App
NODE_ENV=production
PORT=3001
BACKEND_URL=https://votre-backend.railway.app

# URLs des frontends (exactes, sans wildcard)
FRONTEND_ADMIN_URL=https://votre-admin.vercel.app
FRONTEND_OWNER_URL=https://votre-owner.vercel.app

# Supabase — app.supabase.com → ton projet → Settings → API
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=votre-anon-key-ici
SUPABASE_SERVICE_KEY=votre-service-role-key-ici

# Twilio — console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=votre-auth-token-ici
TWILIO_PHONE_WHATSAPP=whatsapp:+14155238886

# Sécurité webhooks — générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=votre-secret-webhook-ici

# SendGrid — app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.votre-cle-sendgrid-ici
SENDGRID_FROM_EMAIL=noreply@staypilot.cc
SENDGRID_FROM_NAME=StayPilot

# Anthropic (Claude IA) — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-votre-cle-anthropic-ici

# Stripe — dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_votre-cle-secrete
STRIPE_PUBLISHABLE_KEY=pk_test_votre-cle-publique
STRIPE_WEBHOOK_SECRET=whsec_votre-webhook-secret

# AWS S3 (stockage PDFs) — aws.amazon.com → IAM → Clés d'accès
AWS_ACCESS_KEY_ID=votre-access-key-id
AWS_SECRET_ACCESS_KEY=votre-secret-access-key
AWS_S3_BUCKET=staypilot-invoices
AWS_REGION=eu-west-3

# Superhote API URL (ne pas changer)
SUPERHOTE_API_URL=https://app.superhote.com/api

# Polling & Scheduler (mettre false pour désactiver en dev)
ENABLE_POLLING=true
ENABLE_SCHEDULER=true
