# ─────────────────────────────────────────────────────────────────────────────
# StayPilot — Variables d'environnement Docker Compose
# Copier en .env et remplir les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# ============================================================
# À REMPLIR POUR CHAQUE CLIENT
# ============================================================

# Domaine de déploiement (ex: app.maconciergerie.fr)
DOMAIN=ton-domaine.com

# Superhote — Paramètres → API → Clé API
SUPERHOTE_API_KEY=

# Twilio — Console → Phone Numbers → ton numéro dédié
TWILIO_PHONE_NUMBER=+33XXXXXXXXX

# Infos conciergerie (affichées dans les PDFs et emails)
CLIENT_NAME=Ma Conciergerie
CLIENT_LOGO_URL=
CLIENT_PHONE=
CLIENT_ADDRESS=
CLIENT_SIRET=
CLIENT_COMMISSION_RATE=20

# ============================================================
# INFRASTRUCTURE (commun à tous les clients)
# ============================================================

# Supabase — app.supabase.com → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Twilio — console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_WHATSAPP=whatsapp:+14155238886

# SendGrid — app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@staypilot.fr
SENDGRID_FROM_NAME=StayPilot

# Anthropic (Claude IA) — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx

# AWS S3 — aws.amazon.com → IAM
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=staypilot-invoices
AWS_REGION=eu-west-3

# n8n
N8N_ENCRYPTION_KEY=changez_moi_minimum_32_caracteres_ici
N8N_USER=admin
N8N_PASSWORD=mot_de_passe_fort_ici

# ============================================================
# SIMULATION / TESTS (optionnel)
# ============================================================
# Email admin Supabase pour le compte de test
SEED_ADMIN_EMAIL=admin@staypilot-test.fr

# Numéro et email pour recevoir les SMS/emails de test
TEST_PHONE=+33600000000
TEST_EMAIL=test@example.com
